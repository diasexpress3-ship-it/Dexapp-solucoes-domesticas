rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===== FUNÇÕES AUXILIARES =====
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.profile == 'admin';
    }
    
    function isCentral() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.profile == 'central';
    }
    
    function isPrestador() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.profile == 'prestador';
    }
    
    function isCliente() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.profile == 'cliente';
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ===== REGRA GERAL: ADMIN E CENTRAL TÊM ACESSO TOTAL =====
    match /{document=**} {
      allow read, write: if isAdmin() || isCentral();
    }
    
    // ===== REGRAS ESPECÍFICAS POR COLEÇÃO =====
    
    // 1. USERS - regras específicas
    match /users/{userId} {
      // Criar conta (sem autenticação)
      allow create: if !isAuthenticated() || request.auth.uid == userId;
      
      // Ler: autenticados, admin, central
      allow read: if isAuthenticated() && (
        isOwner(userId) || 
        isAdmin() || 
        isCentral()
      );
      
      // Atualizar: admin, central, ou próprio usuário
      allow update: if isAuthenticated() && (
        isAdmin() ||
        isCentral() ||
        isOwner(userId)
      );
      
      // Deletar: apenas admin
      allow delete: if isAdmin();
    }
    
    // 2. SOLICITACOES - pedidos de serviço
    match /solicitacoes/{solicitacaoId} {
      // Ler: admin, central, dono, prestador atribuído
      allow read: if isAuthenticated() && (
        isAdmin() ||
        isCentral() ||
        resource.data.clienteId == request.auth.uid ||
        resource.data.prestadorId == request.auth.uid
      );
      
      // Criar: cliente autenticado
      allow create: if isAuthenticated() && isCliente();
      
      // Atualizar: admin, central, dono, prestador atribuído
      allow update: if isAuthenticated() && (
        isAdmin() ||
        isCentral() ||
        resource.data.clienteId == request.auth.uid ||
        (isPrestador() && resource.data.prestadorId == request.auth.uid)
      );
      
      // Deletar: admin ou central
      allow delete: if isAdmin() || isCentral();
    }
    
    // 3. PAGAMENTOS - transações
    match /pagamentos/{pagamentoId} {
      // Ler: admin, central, dono, prestador
      allow read: if isAuthenticated() && (
        isAdmin() ||
        isCentral() ||
        resource.data.clienteId == request.auth.uid ||
        resource.data.prestadorId == request.auth.uid
      );
      
      // Criar: qualquer autenticado
      allow create: if isAuthenticated();
      
      // Atualizar status: admin, central
      allow update: if isAdmin() || isCentral();
      
      // Deletar: admin ou central
      allow delete: if isAdmin() || isCentral();
    }
    
    // 4. SERVICOS - catálogo de serviços
    match /servicos/{servicoId} {
      // Ler: qualquer um (público)
      allow read: if true;
      
      // Escrever: admin ou central
      allow write: if isAdmin() || isCentral();
    }
    
    // 5. RELATÓRIOS - admin e central
    match /relatorios/{relatorioId} {
      allow read, write: if isAdmin() || isCentral();
    }
    
    // 6. CONFIGURAÇÕES - admin e central
    match /config/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isCentral();
    }
    
    // 7. LOGS - admin e central
    match /logs/{logId} {
      allow read, write: if isAdmin() || isCentral();
    }
    
    // 8. EMERGENCIAS - central pode gerir
    match /emergencias/{emergenciaId} {
      allow read, write: if isAuthenticated() && (
        isAdmin() ||
        isCentral() ||
        resource.data.usuarioId == request.auth.uid
      );
    }
    
    // 9. NOTIFICACOES - central pode enviar
    match /notificacoes/{notificacaoId} {
      allow read: if isAuthenticated() && (
        isAdmin() ||
        isCentral() ||
        resource.data.usuarioId == request.auth.uid
      );
      allow write: if isAdmin() || isCentral();
    }
  }
}
