rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields:
    //   - id: string (required)
    //   - nome: string (required)
    //   - email: string (optional)
    //   - telefone: string (required)
    //   - role: string ('cliente', 'prestador', 'central', 'admin')
    //   - status: string ('ativo', 'pendente', 'bloqueado', 'suspenso')
    //   - dataCadastro: timestamp
    //
    // Collection: solicitacoes
    // Fields:
    //   - clienteId: string (required)
    //   - clienteNome: string
    //   - status: string
    //   - valorTotal: number
    //
    // Collection: pagamentos
    // Fields:
    //   - clienteId: string (required)
    //   - valor: number
    //   - status: string
    //
    // Collection: config
    // Fields:
    //   - landingImagens: map
    //   - configuracoes: map
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "startbusiness26@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isCentral() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'central';
    }

    function isValidUser(data) {
      return data.nome is string && data.nome.size() > 0 &&
             data.telefone is string && data.telefone.size() >= 9 &&
             data.role in ['cliente', 'prestador', 'central', 'admin'] &&
             data.status in ['ativo', 'pendente', 'bloqueado', 'suspenso'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin() || isCentral();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (
        (request.resource.data.role == 'cliente' && request.resource.data.status == 'ativo') ||
        (request.resource.data.role == 'prestador' && request.resource.data.status == 'pendente') ||
        isAdmin()
      );
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin() || isCentral();
      allow delete: if isAdmin();
    }

    match /solicitacoes/{solicitacaoId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.clienteId || 
        request.auth.uid == resource.data.prestadorId || 
        isAdmin() || isCentral()
      );
      allow create: if isAuthenticated() && request.resource.data.clienteId == request.auth.uid;
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.clienteId || 
        request.auth.uid == resource.data.prestadorId || 
        isAdmin() || isCentral()
      );
      allow delete: if isAdmin();
    }

    match /pagamentos/{pagamentoId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.clienteId || 
        isAdmin() || isCentral()
      );
      allow create: if isAuthenticated() && request.resource.data.clienteId == request.auth.uid;
      allow update: if isAdmin() || isCentral();
      allow delete: if isAdmin();
    }

    match /config/{configId} {
      allow read: if true; // Public config for landing page
      allow write: if isAdmin();
    }
  }
}
